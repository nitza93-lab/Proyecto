        <DataProperty IRI="#tieneDescripcion"/>
        <NamedIndividual IRI="#rec_EvitarBebidasAzucaradas"/>
        <Literal>Sugiere eliminar refrescos, bebidas endulzadas o jugos con azúcar añadida.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#tieneDescripcion"/>
        <NamedIndividual IRI="#rec_GranosIntegrales"/>
        <Literal>Recomienda sustituir granos refinados por opciones integrales.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#tieneDescripcion"/>
        <NamedIndividual IRI="#rec_GranosRefinados"/>
        <Literal>Aconseja reducir el consumo de pan blanco, arroz blanco y productos de harina refinada.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#tieneDescripcion"/>
        <NamedIndividual IRI="#rec_GrasasSaludables"/>
