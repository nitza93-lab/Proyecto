    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/begum/ontologies/2018/10/untitled-ontology-6#C_peptid">
        <rdfs:comment>Niveles de peptido en sangre</rdfs:comment>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.semanticweb.org/begum/ontologies/2018/10/untitled-ontology-6#FPG">
