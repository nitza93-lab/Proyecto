<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/nitza/ontologies/2025/10/untitled-ontology-es/"
     xml:base="http://www.semanticweb.org/nitza/ontologies/2025/10/untitled-ontology-es/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:CDMOnto="http://www.semanticweb.org/khaled/ontologies/2024/7/CDMOnto#"
     xmlns:untitled-ontology-6="http://www.semanticweb.org/begum/ontologies/2018/10/untitled-ontology-6#"
     xmlns:untitled-ontology-es="http://www.semanticweb.org/nitza/ontologies/2025/10/untitled-ontology-es#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/nitza/ontologies/2025/10/untitled-ontology-es">
        <rdfs:comment>Esta ontología utiliza como referencia principal la Norma Oficial Mexicana NOM-015-SSA2-2010 para la prevención, tratamiento y control de la diabetes mellitus.
Además, se incorporan tratamientos y medicamentos modernos utilizados en guías internacionales recientes, como la American Diabetes Association (ADA) y la International Diabetes Federation (IDF).
Las recomendaciones generadas por el sistema son informativas y no sustituyen la valoración médica.
Cualquier medicamento, ajuste de dosis o modificación terapéutica debe ser autorizado exclusivamente por un profesional de la salud.</rdfs:comment>
    </owl:Ontology>
    


